# ── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pranam

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────
# Access token: short-lived JWT (15 min). Refresh token: opaque UUID in Redis (30 days).
JWT_ACCESS_SECRET=replace-with-a-long-random-string
ACCESS_TOKEN_TTL=900            # seconds (15 min)
REFRESH_TOKEN_TTL=2592000       # seconds (30 days)

# ── MSG91 (SMS OTP) ──────────────────────────────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=PRANAM
MSG91_OTP_TEMPLATE_ID=your-template-id
# When true, OTPs are logged to console instead of sent (local dev)
SMS_DRY_RUN=true

# ── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ── Currency / FX ────────────────────────────────────────
FX_API_URL=https://api.exchangerate.host/latest
FX_CACHE_TTL=21600              # seconds (6 hours)

# ── Auth policy ──────────────────────────────────────────
OTP_TTL=600                     # seconds (10 min)
OTP_MAX_REQUESTS_PER_HOUR=3
OTP_MAX_WRONG_ATTEMPTS=5
OTP_LOCK_SECONDS=1800           # 30 min lock after too many wrong attempts
